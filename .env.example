# Waymark environment example
#
# Waymark now uses React/Vite plus Cloudflare Pages Functions (Hono) and D1.
# Local Worker variables can live in `.dev.vars` for `wrangler pages dev`.
# Frontend-only Vite variables can live in `.env.local`.

# Required for local auth/JWT sessions. Generate a strong random value.
JWT_SECRET=
JWT_EXPIRES_IN_SECONDS=3600

# D1/local-user defaults
DEFAULT_SELF_HOST_ID=selfhost_default_user
SELFHOST_USER_NAME=Me
SELFHOST_USER_EMAIL=selfhost_default_user@localhost

# CORS is mostly for split-origin local dev: Vite on :5173, Wrangler on :8788.
CORS_ORIGINS=http://localhost:5173

# Feature flags (0=disabled, 1=enabled)
ENABLE_GOOGLE_OAUTH=0
ENABLE_MOOD_MUSIC=0
ENABLE_GOOGLE_HEALTH=0

# Legacy Google OAuth, if enabled
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Health API v4, if enabled
GOOGLE_HEALTH_CLIENT_ID=
# Optional: 32-byte URL-safe base64 key for encrypting stored OAuth tokens.
FITNESS_TOKEN_KEY=

# Optional Clerk multi-user auth
# Set CLERK_JWT_KEY as a Cloudflare secret in production:
#   wrangler pages secret put CLERK_JWT_KEY
CLERK_JWT_KEY=
CLERK_AUTHORIZED_PARTIES=http://localhost:5173,http://localhost:8788
# Frontend Clerk publishable key for `.env.local` when Clerk is enabled.
VITE_CLERK_PUBLISHABLE_KEY=

# Optional self-host access key required for local-login outside localhost.
SELFHOST_ACCESS_KEY=

# Do not set VITE_API_URL for normal local or Pages deployments.
# Vite proxies /api to Wrangler locally, and Cloudflare Pages serves /api same-origin.
