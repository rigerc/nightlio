{
  "name": "waymark",
  "private": true,
  "version": "0.1.7",
  "type": "module",
  "description": "A beautiful, self-hosted daily mood tracker and journal",
  "author": "shirsakm",
  "license": "MIT",
  "homepage": "https://github.com/shirsakm/nightlio",
  "repository": {
    "type": "git",
    "url": "https://github.com/shirsakm/nightlio.git"
  },
  "bugs": {
    "url": "https://github.com/shirsakm/nightlio/issues"
  },
  "keywords": [
    "mood-tracker",
    "journal",
    "self-hosted",
    "privacy",
    "react",
    "typescript",
    "cloudflare",
    "hono",
    "d1"
  ],
  "scripts": {
    "dev": "vite",
    "build": "NODE_OPTIONS='--max-old-space-size=768' vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit && tsc --noEmit -p functions/tsconfig.json",
    "test": "npm run typecheck && npm run lint",
    "pages:dev": "npm run build && wrangler pages dev dist --compatibility-date=2025-01-01 --compatibility-flags=nodejs_compat",
    "pages:deploy": "npm run build && wrangler pages deploy dist",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote",
    "db:migrate-data": "node scripts/migration/sqlite-to-d1.mjs"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.8.0",
    "@hookform/resolvers": "^5.4.0",
    "@mdxeditor/editor": "^3.11.6",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^5.85.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "googlehealth": "^0.1.0",
    "hono": "^4.12.23",
    "hono-rate-limiter": "^0.5.3",
    "lucide-react": "^0.460.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-hook-form": "^7.77.0",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^7.9.6",
    "recharts": "^2.12.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260607.1",
    "@eslint/js": "^9.32.0",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitejs/plugin-react": "^4.7.0",
    "better-sqlite3": "^12.10.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.32.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "rollup-plugin-visualizer": "^6.0.5",
    "typescript": "^6.0.3",
    "vite": "^7.1.0",
    "wrangler": "^4.98.0"
  }
}
