{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".expo/types/**/*.d.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts"
  ],
  "exclude": [
    "node_modules",
    "src/services/api.ts",
    "src/services/fitnessApi.ts",
    "src/hooks/useSyncPreferences.ts",
    "src/contexts",
    "src/views",
    "src/App.tsx",
    "src/main.tsx",
    "src/vite-env.d.ts",
    "src/index.css",
    "src/App.css",
    "src/lib/utils.ts",
    "src/utils/entryUtils.ts",
    "src/utils/exportUtils.ts",
    "src/utils/iconUtils.ts",
    "src/components/auth",
    "src/components/FAB.tsx",
    "src/components/Header.tsx",
    "src/components/Header.css",
    "src/components/MarkdownArea.tsx",
    "src/components/MarkdownArea.css",
    "src/components/Navigation.tsx",
    "src/components/navigation",
    "src/components/search",
    "src/components/journal",
    "src/components/history/AddEntryCard.tsx",
    "src/components/history/EntryModal.tsx",
    "src/components/groups/GroupManager.tsx",
    "src/components/groups/SliderValueBar.tsx",
    "src/components/goals/AddGoalCard.tsx",
    "src/components/goals/GoalStatsCalendar.tsx",
    "src/components/goals/GoalsSection.tsx",
    "src/components/ui/button.tsx",
    "src/components/ui/ColorPicker.tsx",
    "src/components/ui/IconPicker.tsx",
    "src/components/ui/ToastProvider.tsx",
    "src/components/ui/badge.tsx",
    "src/components/ui/dialog.tsx",
    "src/components/ui/progress.tsx",
    "src/components/mood/MoodLogList.tsx",
    "src/components/fitness/FitnessConnectSection.tsx",
    "src/shared/schemas/auth.ts",
    "src/shared/schemas/fitness.ts",
    "src/shared/schemas/preferences.ts",
    "src/shared/schemas/index.ts"
  ]
}
