# Example environment for Waymark
# Copy to `.env` at the repo root for backend and `.env.local` for frontend

# Backend (.env)
RAILWAY_ENVIRONMENT=development
PORT=5000
SECRET_KEY=
# Required: set a strong random value before deploying
JWT_SECRET=
CORS_ORIGINS=http://localhost:5173

# Feature flags (0=disabled, 1=enabled)
ENABLE_GOOGLE_OAUTH=0
ENABLE_MOOD_MUSIC=0

# Self-host defaults
DEFAULT_SELF_HOST_ID=selfhost_default_user

# Database (optional; defaults to data/nightlio.db)
# DATABASE_PATH=

# Google OAuth (only if ENABLE_GOOGLE_OAUTH=1)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=

# Web3 removed

# Mood music (only if ENABLE_MOOD_MUSIC=1)
JAMENDO_CLIENT_ID=

# Google Health API v4 (only if ENABLE_GOOGLE_HEALTH=1)
# Requires a GCP OAuth 2.0 client with the following consent-screen scopes:
#   https://www.googleapis.com/auth/googlehealth.activity_and_fitness.readonly
#   https://www.googleapis.com/auth/googlehealth.sleep.readonly
#   https://www.googleapis.com/auth/googlehealth.health_metrics_and_measurements.readonly
# Note: Use a PKCE-capable public client (no client_secret needed).
ENABLE_GOOGLE_HEALTH=0
GOOGLE_HEALTH_CLIENT_ID=
FRONTEND_URL=http://localhost:5173
# Optional: 32-byte URL-safe base64 Fernet key to encrypt stored OAuth tokens.
# Leave blank to auto-derive from JWT_SECRET.
FITNESS_TOKEN_KEY=

# Cloudflare Pages + Clerk multi-user auth
# Set CLERK_JWT_KEY via `wrangler secret put CLERK_JWT_KEY` in production.
# CLERK_AUTHORIZED_PARTIES should include trusted app origins, comma-separated.
CLERK_AUTHORIZED_PARTIES=http://localhost:5173,http://localhost:8788
# For protected self-host local login outside localhost:
SELFHOST_ACCESS_KEY=

# Frontend (.env.local)
VITE_API_URL=http://localhost:5000
# Clerk publishable key enables Clerk UI/session handling in the React app.
VITE_CLERK_PUBLISHABLE_KEY=
# If enabling legacy Google OAuth, also set on the frontend
# VITE_GOOGLE_CLIENT_ID=